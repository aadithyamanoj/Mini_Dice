.PHONY: lint sim sim-vcs clean

SHELL := /bin/bash

TB         ?= tb_dice_frontend_top
DICE_HOME  ?= $(shell cd ../../.. && pwd)
BUILD_DIR  := build

VERILATOR_FLAGS  = --lint-only
VERILATOR_FLAGS += --timing
VERILATOR_FLAGS += --top-module $(TB)
VERILATOR_FLAGS += -Wall
VERILATOR_FLAGS += -Wno-TIMESCALEMOD
VERILATOR_FLAGS += -Wno-CASEINCOMPLETE
VERILATOR_FLAGS += -Wno-SYNCASYNCNET
VERILATOR_FLAGS += -Wno-PINMISSING
VERILATOR_FLAGS += -Wno-UNDRIVEN
VERILATOR_FLAGS += -Wno-UNUSEDSIGNAL
VERILATOR_FLAGS += -Wno-UNUSEDPARAM
VERILATOR_FLAGS += -Wno-WIDTHEXPAND
VERILATOR_FLAGS += -Wno-WIDTHTRUNC
VERILATOR_FLAGS += -Wno-ASCRANGE
VERILATOR_FLAGS += -Wno-DECLFILENAME
VERILATOR_FLAGS += -Wno-EOFNEWLINE
VERILATOR_FLAGS += -Wno-PINCONNECTEMPTY
VERILATOR_FLAGS += -Wno-GENUNNAMED
VERILATOR_FLAGS += -Wno-IMPLICITSTATIC

VERILATOR_SIM_FLAGS  = --binary
VERILATOR_SIM_FLAGS += --timing
VERILATOR_SIM_FLAGS += --top-module $(TB)
VERILATOR_SIM_FLAGS += -Wall
VERILATOR_SIM_FLAGS += -Wno-TIMESCALEMOD
VERILATOR_SIM_FLAGS += -Wno-CASEINCOMPLETE
VERILATOR_SIM_FLAGS += -Wno-SYNCASYNCNET
VERILATOR_SIM_FLAGS += -Wno-PINMISSING
VERILATOR_SIM_FLAGS += -Wno-UNDRIVEN
VERILATOR_SIM_FLAGS += -Wno-UNUSEDSIGNAL
VERILATOR_SIM_FLAGS += -Wno-UNUSEDPARAM
VERILATOR_SIM_FLAGS += -Wno-WIDTHEXPAND
VERILATOR_SIM_FLAGS += -Wno-WIDTHTRUNC
VERILATOR_SIM_FLAGS += -Wno-ASCRANGE
VERILATOR_SIM_FLAGS += -Wno-DECLFILENAME
VERILATOR_SIM_FLAGS += -Wno-EOFNEWLINE
VERILATOR_SIM_FLAGS += -Wno-PINCONNECTEMPTY
VERILATOR_SIM_FLAGS += -Wno-GENUNNAMED
VERILATOR_SIM_FLAGS += -Wno-IMPLICITSTATIC

$(BUILD_DIR):
	@mkdir -p $(BUILD_DIR)

lint:
	@echo "Running Verilator lint on $(TB)..."
	@DICE_HOME=$(DICE_HOME) verilator $(VERILATOR_FLAGS) -f filelist.f
	@echo "Lint passed."

sim-verilator: | $(BUILD_DIR)
	@echo "Running Verilator sim on $(TB)..."
	@DICE_HOME=$(DICE_HOME) verilator $(VERILATOR_SIM_FLAGS) -f filelist.f
	@./obj_dir/V$(TB)

sim: | $(BUILD_DIR)
	@echo "Running VCS sim with TOP=$(TB)"
	@cd $(BUILD_DIR) && TB_TOP=$(TB) DICE_HOME=$(DICE_HOME) tclsh ../run_vcs.tcl

clean:
	@echo "Cleaning build artifacts..."
	@rm -rf $(BUILD_DIR) obj_dir
	@echo "Done."
